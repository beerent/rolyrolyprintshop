{
  "name": "rollie-pollie-print-shop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node server.mjs",
    "check": "node --check app.js && node --check build.mjs && node --check server.mjs",
    "deploy": "firebase deploy",
    "deploy:rules": "firebase deploy --only auth,firestore:rules,storage",
    "deploy:cors": "gcloud storage buckets update gs://rolyrolyprintshop.firebasestorage.app --cors-file=storage.cors.json"
  }
}
